{
  "crons": [
    {
      "path": "/api/daily-digest",
      "schedule": "0 5 * * 1-5"
    }
  ],
  "functions": {
    "app/api/upload-media/route.ts": {
      "maxDuration": 60
    },
    "app/api/upload-media/presign/route.ts": {
      "maxDuration": 30
    },
    "app/api/upload-media/confirm/route.ts": {
      "maxDuration": 30
    }
  }
}
